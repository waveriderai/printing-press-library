{
  "name": "@mvanhorn/printing-press-library",
  "version": "0.1.13",
  "description": "Installer and catalog CLI for Printing Press-generated CLIs.",
  "type": "module",
  "license": "MIT",
  "author": "Matt Van Horn <mvanhorn@gmail.com>",
  "contributors": [
    "Trevin Chow <trevin@trevinchow.com>"
  ],
  "homepage": "https://printingpress.dev",
  "bugs": {
    "url": "https://github.com/mvanhorn/printing-press-library/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvanhorn/printing-press-library.git",
    "directory": "npm"
  },
  "keywords": [
    "cli",
    "claude",
    "agent",
    "go",
    "openapi",
    "skills",
    "printing-press",
    "installer"
  ],
  "bin": {
    "printing-press-library": "bin/printing-press-library.mjs"
  },
  "files": [
    "bin/",
    "CHANGELOG.md",
    "dist/src/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "prepublishOnly": "npm test && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.19.39",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6"
  }
}
